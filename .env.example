OPENAI_API_KEY=your_openai_api_key

# Optional (src_v1): provider:model for init_chat_model — e.g. openai:gpt-4o-mini, anthropic:claude-sonnet-4-20250514
# Install the matching package (langchain-openai, langchain-anthropic, …) and its API key env vars.
CHAT_MODEL=openai:gpt-5-mini

# Optional: override project folders (defaults: <repo>/src and <repo>/data)
CRDF_SRC_DIR=/path/to/CRDFAgent/src
CRDF_DATA_DIR=/path/to/CRDFAgent/data

# Optional: where ``src/runme.py`` writes JSON and ``scoring.py`` reads/writes (default: <data>/results).
# Use a separate folder to keep a clean “original pipeline” snapshot, e.g.:
# CRDF_RESULTS_DIR=/path/to/CRDFAgent/data/results_original
CRDF_RESULTS_DIR=

# Optional: logging for aggregator / safe_exec (default INFO). Use DEBUG to log full code at exec time.
CRDF_LOG_LEVEL=INFO